                  "  console.log('storeId set to:', stores[0]._id);",
                  "} else {",
                  "  console.warn('No stores found — create a store then manually set storeId in the environment');",
                  "}"
                ]
              }
            }
          ]
        },

        {
          "name": "Get Store by Slug",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stores/test-store",
              "host": ["{{baseUrl}}"],
              "path": ["stores", "test-store"],
              "description": "Replace 'test-store' with an actual store slug from your DB"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Store may or may not exist — accept 200 or 404",
                  "pm.test('Status is 200 or 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.test('Store has required fields', () => {",
                  "    pm.expect(json.data.store._id).to.be.a('string');",
                  "    pm.expect(json.data.store.name).to.be.a('string');",
                  "    pm.expect(json.data.store.slug).to.be.a('string');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }

      ]
    },

    {
      "name": "Products",
      "item": [

        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store\": \"{{storeId}}\",\n  \"name\": \"test_product Sepatu Running Pro\",\n  \"description\": \"Sepatu lari ringan untuk semua medan.\",\n  \"price\": 299000,\n  \"stock\": 50,\n  \"category\": \"sports\",\n  \"images\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Product has _id', () => {",
                  "  pm.expect(json.data.product._id).to.be.a('string');",
                  "});",
                  "pm.test('Product name matches', () => {",
                  "  pm.expect(json.data.product.name).to.include('test_product');",
                  "});",
                  "pm.test('Price is a number', () => {",
                  "  pm.expect(json.data.product.price).to.be.a('number');",
                  "});",
                  "pm.test('isActive defaults to true', () => {",
                  "  pm.expect(json.data.product.isActive).to.be.true;",
                  "});",
                  "",
                  "// Propagate productId for subsequent requests",
                  "pm.environment.set('productId', json.data.product._id);",
                  "console.log('productId set to:', json.data.product._id);"
                ]
              }
            }
          ]
        },

        {
          "name": "List Products",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?store={{storeId}}&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "store",  "value": "{{storeId}}" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Products is an array', () => {",
                  "  pm.expect(json.data.products).to.be.an('array');",
                  "});",
                  "pm.test('Pagination object is present', () => {",
                  "  pm.expect(json.data.pagination).to.be.an('object');",
                  "  pm.expect(json.data.pagination.total).to.be.a('number');",
                  "  pm.expect(json.data.pagination.page).to.eql(1);",
                  "  pm.expect(json.data.pagination.limit).to.eql(10);",
                  "  pm.expect(json.data.pagination.pages).to.be.a('number');",
                  "});",
                  "pm.test('At least one product exists', () => {",
                  "  pm.expect(json.data.products.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Get Product by ID",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Product _id matches environment variable', () => {",
                  "  pm.expect(json.data.product._id).to.eql(pm.environment.get('productId'));",
                  "});",
                  "pm.test('Store is populated (has name)', () => {",
                  "  pm.expect(json.data.product.store).to.be.an('object');",
                  "  pm.expect(json.data.product.store.name).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 249000,\n  \"stock\": 45,\n  \"description\": \"Updated — Sepatu lari ringan, sekarang lebih hemat!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Price was updated', () => {",
                  "  pm.expect(json.data.product.price).to.eql(249000);",
                  "});",
                  "pm.test('Stock was updated', () => {",
                  "  pm.expect(json.data.product.stock).to.eql(45);",
                  "});",
                  "pm.test('isActive is still true after update', () => {",
                  "  pm.expect(json.data.product.isActive).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Delete Product (soft delete)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Product is soft-deleted (isActive = false)', () => {",
                  "  pm.expect(json.data.product.isActive).to.be.false;",
                  "});",
                  "pm.test('Product _id is unchanged', () => {",
                  "  pm.expect(json.data.product._id).to.eql(pm.environment.get('productId'));",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "List Products — filter by category",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?store={{storeId}}&category=sports&page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "store",    "value": "{{storeId}}" },
                { "key": "category", "value": "sports" },
                { "key": "page",     "value": "1" },
                { "key": "limit",    "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('All returned products belong to sports category', () => {",
                  "  json.data.products.forEach(p => {",
                  "    pm.expect(p.category).to.eql('sports');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }

      ]
    },

    {
      "name": "Upload",
      "item": [

        {
          "name": "Upload Product Images",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "src": [],
                  "description": "Select one or more image files (JPEG / PNG / WebP / GIF, max 5 MB each, max 10 files)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/products/images",
              "host": ["{{baseUrl}}"],
              "path": ["products", "images"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Images array is returned', () => {",
                  "  pm.expect(json.data.images).to.be.an('array').and.not.empty;",
                  "});",
                  "pm.test('Each image has url and publicId', () => {",
                  "  json.data.images.forEach(img => {",
                  "    pm.expect(img.url).to.be.a('string').and.include('cloudinary.com');",
                  "    pm.expect(img.publicId).to.be.a('string').and.not.empty;",
                  "  });",
                  "});",
                  "",
                  "// Save first URL so you can paste it into a Create Product body",
                  "if (json.data.images.length > 0) {",
                  "  pm.environment.set('uploadedImageUrl', json.data.images[0].url);",
                  "  pm.environment.set('uploadedImagePublicId', json.data.images[0].publicId);",
                  "}"
                ]
              }
            }
          ]
        },

