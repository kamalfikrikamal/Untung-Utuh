    {
      "name": "Stores",
      "item": [

        {
          "name": "Create Store",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toko Test Saya\",\n  \"description\": \"Toko percobaan untuk testing API\",\n  \"whatsapp\": \"+6281234567890\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/stores",
              "host": ["{{baseUrl}}"],
              "path": ["stores"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Store has _id and slug', () => {",
                  "  pm.expect(json.data.store._id).to.be.a('string');",
                  "  pm.expect(json.data.store.slug).to.be.a('string');",
                  "});",
                  "",
                  "// Auto-save storeId for subsequent requests",
                  "pm.environment.set('storeId', json.data.store._id);",
                  "console.log('storeId set to:', json.data.store._id, '| slug:', json.data.store.slug);"
                ]
              }
            }
          ]
        },

        {
          "name": "Get My Stores",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stores/my",
              "host": ["{{baseUrl}}"],
              "path": ["stores", "my"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Response status is success', () => {",
                  "  pm.expect(json.status).to.eql('success');",
                  "});",
                  "pm.test('Stores is an array', () => {",
                  "  pm.expect(json.data.stores).to.be.an('array');",
                  "});",
                  "",
                  "// Auto-extract first store ID for subsequent requests",
                  "const stores = json.data.stores;",
