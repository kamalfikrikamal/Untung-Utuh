# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Root environment variables used by docker-compose
# Copy to .env, .env.staging, .env.production and fill in real values
# NEVER commit real .env files to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=CHANGE_THIS_STRONG_ROOT_PASSWORD
MONGO_DB=mernapp
MONGO_APP_USER=mernapp_user
MONGO_APP_PASSWORD=CHANGE_THIS_STRONG_APP_PASSWORD

# ── Frontend Build Args ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
VITE_APP_NAME=MERN App
VITE_APP_URL=http://localhost
